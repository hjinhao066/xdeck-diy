{
  "name": "xdeck-diy",
  "version": "1.4.0",
  "description": "DIY multi-column X (Twitter) deck - TweetDeck/X Pro alternative for Win & Mac",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test": "node tests/layout-width.test.js",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win --publish never"
  },
  "author": "jinhao",
  "license": "MIT",
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.jinhao.xdeckdiy",
    "productName": "XDeck DIY",
    "files": [
      "main.js",
      "preload.js",
      "webview-preload.js",
      "index.html",
      "shared-layout.js",
      "renderer.js",
      "style.css"
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.social-networking",
      "icon": "build/icon.icns"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    }
  }
}
